{
  "compilerOptions": {
    "outDir": "lib",
    "module": "commonjs",
    "target": "es2019",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/index.ts",
    "src/incrementAttendance.ts",
    "src/modules/xp/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "lib"
  ]
}
