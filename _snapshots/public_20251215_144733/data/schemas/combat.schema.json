{
  "$id": "combat.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tierIndex": { "type": "integer", "minimum": 0 },
    "xpCurrent": { "type": "integer", "minimum": 0 },
    "xpCap":    { "type": "integer", "minimum": 0 },
    "status":   { "type": "string", "enum": ["active","inactive","suspended"] },
    "characterBank": { "type": "integer", "minimum": 0 },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "currentCycleAttempts": { "type": "integer", "minimum": 0 },
        "lastResult": { "type": "string" }
      },
      "required": ["currentCycleAttempts","lastResult"]
    },
    "cooldowns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lastTestFail": { "type": ["string","null"], "description": "ISO timestamp or null" },
        "lastDomination": { "type": ["string","null"], "description": "ISO timestamp or null" }
      }
    },
    "totals": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "attendance": { "type": "integer", "minimum": 0 },
        "assignments": { "type": "integer", "minimum": 0 },
        "characters": { "type": "integer", "minimum": 0 },
        "tournaments": { "type": "integer", "minimum": 0 }
      },
      "required": ["attendance","assignments","characters","tournaments"]
    }
  },
  "required": ["tierIndex","xpCurrent","xpCap","status","characterBank","tests","cooldowns","totals"]
}
