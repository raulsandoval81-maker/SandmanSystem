{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "src",
    "outDir": "lib",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "lib",
    "node_modules",
    "_archived",
    "_v1_disabled",
    "_lib_old",
    "**/*.DISABLED"
  ]
}
