{
  "name": "sandman-functions",
  "private": true,
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "build:watch": "tsc -w",
    "serve": "firebase emulators:start --only functions,firestore,hosting,auth --import=../emulator-data --export-on-exit=../emulator-data --debug",
    "clean": "rimraf lib && rimraf node_modules"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^4.7.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^20.19.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
