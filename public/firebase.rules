rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* --------------------------------------
       Para-Comms V1: Unified Parent ↔ Coach Thread
    ---------------------------------------*/
    match /paraParentInbox/{threadId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "parentName","parentEmail","parentKey","subject",
          "lastBody","lastReplyAt",
          "coachHasUnread","parentHasUnread",
          "seenByCoach","seenByParent",
          "coachOpenedAt","parentOpenedAt"
        ]);

      allow delete: if false;

      match /thread/{messageId} {
        allow read: if request.auth != null;

        allow create: if request.auth != null
          && request.resource.data.keys().hasOnly([
            "from","fromName","body","createdAt",
            "seenByCoach","seenByParent"
          ])
          && request.resource.data.from in ["parent","coach"]
          && request.resource.data.body is string
          && request.resource.data.body.size() > 0
          && request.resource.data.body.size() <= 2000;

        allow update, delete: if false;
      }
    }

    /* --------------------------------------
       Para-Comms V1 Announcements (Broadcast)
       Collection: paraAnnouncements/{id}
    ---------------------------------------*/
    match /paraAnnouncements/{id} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.teamId is string
        && request.resource.data.category is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.audienceType is string
        && request.resource.data.from is string
        && request.resource.data.fromName is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 3000;

      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "pinned","pinnedAt","unpinnedAt",
          "archived","archivedAt",
          "deleted","deletedAt",
          "title","message","editedAt"
        ]);

      allow delete: if false;
    }

    /* --------------------------------------
       Coach Roster: Athletes (READ ONLY) + Onboarding Confirm (NARROW UPDATE)
       (Roster pages LIST this collection)
    ---------------------------------------*/
    match /athletes/{uid} {
      allow read: if request.auth != null;  // enables LIST + GET

      // ✅ ONLY CHANGE: allow athlete to confirm onboarding on their own athlete doc
      // Doc id may be F4_#### / F8_####, so we match using an auth uid field stored in the document.
      
allow update: if request.auth != null
  && request.resource.data.diff(resource.data).changedKeys().hasOnly([
    "identityConfirmed",
    "identityConfirmedAt",
    "onboardingStep",
    "onboardedAt",
    "status",
    "updatedAt",
    "assignments"
  ]);


      // everything else stays locked
      allow create, delete: if false;
    }

    /* --------------------------------------
       Legacy pilot collections (keep only if still used)
    ---------------------------------------*/
    match /parentInbox/{month}/entries/{msgId} {
      allow write: if true;   // legacy open write
      allow read: if false;
    }

    match /bulletin/{month}/entries/{id} {
      allow read: if true;    // legacy public read
      allow write: if false;
    }

    /* --------------------------------------
       Intake
    ---------------------------------------*/
    match /intakeTokens/{id} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;

      // ✅ ONLY CHANGE: allow athlete to confirm identity on their own token doc (narrow fields only)
allow update: if request.auth != null
  && (
    request.auth.uid == resource.data.authUid
    || request.auth.uid == resource.data.uid
    || request.auth.uid == resource.data.userUid
    || request.auth.uid == resource.data.firebaseUid
    || request.auth.uid == resource.data.athleteUid
  )
  && request.resource.data.diff(resource.data).changedKeys().hasOnly([
    "identityConfirmed",
    "identityConfirmedAt",
    "onboardingStep",
    "onboardedAt",
    "status",
    "updatedAt"
  ]);
      allow delete: if false;
    }

    match /intakePending/{id} {
      allow create: if true;
      allow read, update, delete: if false;
    }

    /* --------------------------------------
       Vault
    ---------------------------------------*/
    match /vaultSessions/{id} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /laneSubmissions/{athleteId} {
      allow read, create, update: if request.auth != null;
    }


match /laneHistory/{id} {
  allow read, create: if request.auth != null;
  allow update, delete: if false;
}


    /* -----------------------------
       DEFAULT: CLOSED (MUST BE LAST)
    ------------------------------*/
    match /{document=**} {
      allow read, write: if false;
    }
  }
}